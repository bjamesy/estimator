# RabbitMQ connection string, e.g. amqps://user:pass@host/vhost (CloudAMQP gives you this directly)
MESSAGE_BROKER_URL=

# Supabase project settings -> API
SUPABASE_URL=

# Supabase project settings -> API -> Secret keys.
# The worker writes document_processing_events and extraction_results directly, bypassing RLS by design.
SUPABASE_SECRET_KEY=

# Added in Phase 2 -- vision LLM for extraction. Not required until then.
ANTHROPIC_API_KEY=
