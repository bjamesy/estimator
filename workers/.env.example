# RabbitMQ connection string, e.g. amqps://user:pass@host/vhost (CloudAMQP gives you this directly)
MESSAGE_BROKER_URL=

# Supabase project settings -> API
SUPABASE_URL=

# Supabase project settings -> API -> Secret keys.
# The worker writes document_processing_events, extraction_results, and
# material_matches/material_catalog directly, bypassing RLS by design.
SUPABASE_SECRET_KEY=

# Required. Vision LLM for extraction (extraction.py) and the batched
# matching call for material_matches (matching.py).
ANTHROPIC_API_KEY=

# Email notifications (change orders -- docs/v2/plans/01-change-orders-plan.md
# -> Phase 5). Optional: without RESEND_API_KEY, emails are logged to the
# worker console instead of sent.
RESEND_API_KEY=
EMAIL_FROM=
# Base URL for links the worker builds itself (reminder emails).
APP_BASE_URL=http://localhost:3000
