# RabbitMQ connection string, e.g. amqp://user:pass@host:5672/vhost (CloudAMQP gives you this directly)
RABBITMQ_URL=

# Supabase project settings -> API
SUPABASE_URL=

# Supabase project settings -> API -> service_role secret.
# The worker writes document_processing_events and extraction_results directly, bypassing RLS by design.
SUPABASE_SERVICE_ROLE_KEY=

# Added in Phase 2 -- vision LLM for extraction. Not needed until then.
# ANTHROPIC_API_KEY=
