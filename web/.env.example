# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase project settings -> API -> Secret keys.
# Server-side only (e.g. company creation route) -- bypasses RLS. Never expose to the client.
SUPABASE_SECRET_KEY=

# Supabase project settings -> API -> JWT Keys.
# Not wired into any code path yet -- available for manual JWT verification if a route
# ever needs to validate a bearer token outside the @supabase/ssr cookie session flow.
SUPABASE_JWKS_URL=

# RabbitMQ connection string. Next.js publishes process_document (on
# upload) and match_materials (on confirm) tasks here; workers/ consumes them.
MESSAGE_BROKER_URL=
